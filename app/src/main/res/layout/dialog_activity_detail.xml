<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="activity"
            type="com.mingyuwu.barurside.data.Activity" />

        <variable
            name="user"
            type="com.mingyuwu.barurside.data.User" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/border_activity_detail"
        android:layout_gravity="center">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_add_activity_time"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/ic_baseline_access_time_24"
                android:backgroundTint="@color/black_3f3a3a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/activity_detail_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="2021/10/1 下午 1:00 至 2021/10/1 下午 3:00"
                tools:text="2021/10/1 下午 1:00 至 2021/10/1 下午 3:00"
                app:layout_constraintBottom_toBottomOf="@+id/img_add_activity_time"
                app:layout_constraintStart_toEndOf="@+id/img_add_activity_time"
                app:layout_constraintTop_toTopOf="@+id/img_add_activity_time" />

            <TextView
                android:id="@+id/activity_detail_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="@{activity.name}"
                tools:text="酒中豪傑 Crazy Friday"
                android:textColor="@color/black_3f3a3a"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_add_activity_time" />

            <ImageView
                android:id="@+id/img_add_activity_address"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/ic_baseline_location_on_24"
                android:backgroundTint="@color/black_3f3a3a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/activity_detail_name" />

            <TextView
                android:id="@+id/activity_detail_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@{activity.address}"
                tools:text="新北市新莊區中正路1號"
                app:layout_constraintBottom_toBottomOf="@+id/img_add_activity_address"
                app:layout_constraintStart_toEndOf="@+id/img_add_activity_address"
                app:layout_constraintTop_toTopOf="@+id/img_add_activity_address" />

            <TextView
                android:id="@+id/activity_detail_limit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@{@string/activity_detail_limit(activity.bookers.size(), activity.peopleLimit)}"
                tools:text="11 / 20"
                app:layout_constraintBottom_toBottomOf="@+id/img_activity_detail"
                app:layout_constraintStart_toEndOf="@+id/img_activity_detail"
                app:layout_constraintTop_toTopOf="@+id/img_activity_detail" />

            <TextView
                android:id="@+id/activity_detail_main"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text = "@{activity.mainDrinking}"
                tools:text="雞尾酒"
                app:layout_constraintBottom_toBottomOf="@+id/img_activity_detail_main"
                app:layout_constraintStart_toEndOf="@+id/img_activity_detail_main"
                app:layout_constraintTop_toTopOf="@+id/img_activity_detail_main" />

            <ImageView
                android:id="@+id/img_activity_detail"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/icons_24px_profile"
                android:backgroundTint="@color/black_3f3a3a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_add_activity_address" />

            <ImageView
                android:id="@+id/img_activity_detail_main"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/ic_outline_local_drink_24"
                android:backgroundTint="@color/black_3f3a3a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_activity_detail" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint_sponsor_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:background="@color/gray_f0f0f0"
                android:foreground="@drawable/border_activity_detail"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_activity_detail_main">

                <ImageView
                    android:id="@+id/img_activity_detail_sponsor"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/ic_baseline_sponsor_24"
                    android:backgroundTint="@color/black_3f3a3a"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/profile_base_img"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="250dp"
                    app:cardMaxElevation="5dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/img_activity_detail_sponsor">

                    <ImageView
                        android:id="@+id/img_rtg_user"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        app:imageUrl="@{user.image}"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:src="@tools:sample/backgrounds/scenic" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/rtg_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@{user.name}"
                    app:layout_constraintStart_toEndOf="@+id/profile_base_img"
                    app:layout_constraintTop_toTopOf="@+id/profile_base_img"
                    tools:text="無尾熊" />

                <ImageView
                    android:id="@+id/img_user_post_cnt"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="8dp"
                    android:src="@drawable/ic_baseline_menu_24"
                    app:layout_constraintStart_toEndOf="@+id/profile_base_img"
                    app:layout_constraintTop_toBottomOf="@+id/rtg_user_name" />

                <TextView
                    android:id="@+id/user_post_cnt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@{user.shareCount.toString()}"
                    app:layout_constraintStart_toEndOf="@+id/img_user_post_cnt"
                    app:layout_constraintTop_toTopOf="@+id/img_user_post_cnt"
                    tools:text="569" />

                <ImageView
                    android:id="@+id/img_user_postimg_cnt"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/ic_baseline_image_24"
                    android:backgroundTint="@color/black_3f3a3a"
                    app:layout_constraintStart_toEndOf="@+id/user_post_cnt"
                    app:layout_constraintTop_toTopOf="@+id/img_user_post_cnt" />

                <TextView
                    android:id="@+id/user_postimg_cnt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@{user.shareImageCount.toString()}"
                    app:layout_constraintStart_toEndOf="@+id/img_user_postimg_cnt"
                    app:layout_constraintTop_toTopOf="@+id/img_user_post_cnt"
                    tools:text="569" />

                <TextView
                    android:id="@+id/see_user_profile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text=">"
                    app:layout_constraintStart_toEndOf="@+id/user_postimg_cnt"
                    app:layout_constraintTop_toTopOf="@+id/user_postimg_cnt" />

                <TextView
                    android:id="@+id/txt_activity_detail_sponsor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="發起人"
                    app:layout_constraintBottom_toBottomOf="@+id/img_activity_detail_sponsor"
                    app:layout_constraintStart_toEndOf="@+id/img_activity_detail_sponsor"
                    app:layout_constraintTop_toTopOf="@+id/img_activity_detail_sponsor" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <Button
                android:id="@+id/btn_book_activity"
                style="@style/RatingButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:text="加入活動"
                android:textSize="14sp"
                app:backgroundTint="@color/green_0ead69"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraint_sponsor_info" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>